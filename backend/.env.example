# ---- Nexus BI backend configuration ----
# Everything below is OPTIONAL. With no values set, Nexus runs fully:
#   * SQLite demo seeded from the real Olist CSVs (no Postgres needed)
#   * deterministic planner/SQL-generator/narrator (no LLM key needed)

ENVIRONMENT=local

# --- LLM (free tiers only; leave blank for the zero-key deterministic engine) ---
# GROQ_API_KEY=gsk_...                 # free at console.groq.com
# GROQ_MODEL=llama-3.3-70b-versatile
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
LLM_PROVIDER=auto                       # auto | groq | ollama | deterministic

# --- App metadata DB (connections, history, dashboards, audit) ---
# Default is a local SQLite file. For production, point at Supabase Postgres.
# APP_DB_URL=postgresql://user:pass@db.supabase.co:5432/postgres

# --- Target (analyzed) DB ---
# Default is the bundled read-only SQLite demo. For the Postgres path, use a
# READ-ONLY DSN (see data package's read_only_role.sql).
# DEMO_TARGET_URL=postgresql://nexus_readonly:pass@host:5432/nexus_demo
TARGET_STATEMENT_TIMEOUT_S=8
TARGET_ROW_CAP=10000

# --- RAG (local, no key). Set true to use bge-small if installed. ---
USE_EMBEDDINGS=false

# --- Security ---
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-too              # encrypts stored target DSNs at rest
REQUIRE_AUTH=false                        # true = API key/JWT needed for custom connections & queries
ALLOW_LOCAL_TARGETS=false                 # true only in dev; false = SSRF-safe (blocks private hosts)
RATE_LIMIT_REQUESTS=30                    # per client per window
RATE_LIMIT_WINDOW_S=60

# --- Observability (optional free tier) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# --- CORS (frontend origin) ---
CORS_ORIGINS=["http://localhost:3000"]
